# ==========================================
# Dependencies (Never commit node_modules)
# ==========================================
node_modules/
/jspm_packages/
/web_modules/

# ==========================================
# Production Builds & Outputs
# ==========================================
# React / Frontend builds
dist/
build/
out/

# Node.js / Backend compiled code (TypeScript)
bin/

# ==========================================
# Secrets and Environment Variables
# ==========================================
# Crucial: Never commit actual API keys or secrets
.env.local
.env.development.local
.env.test.local

# ==========================================
# Logs and Debugging
# ==========================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==========================================
# Testing & Code Coverage
# ==========================================
coverage/
.nyc_output/
.jest/
*.spec.js.snap
*.test.js.snap

